{
  "name": "@agency/cli",
  "version": "0.1.0",
  "description": "Agency CLI — CodexAI skills harness (agency + acg TUI)",
  "license": "MIT",
  "keywords": ["cli", "codex", "skills", "tui", "ai", "agent"],
  "type": "module",
  "engines": { "node": ">=22" },
  "files": ["dist", "skills", ".codex-plugin", ".claude-plugin", ".agents", "hooks"],
