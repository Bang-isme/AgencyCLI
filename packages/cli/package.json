    "@agency/tui": "workspace:*",
    "@agency/benchmark": "workspace:*",
    "commander": "^12.0.0",
    "execa": "^9.0.0"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "publishConfig": { "access": "public" }
