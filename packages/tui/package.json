{
  "name": "@agency/tui",
  "version": "0.1.0",
  "description": "Ink TUI for Agency CLI (Agency-style shell)",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=22" },
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "@agency/core": "workspace:*",
    "@agency/providers": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "ink-testing-library": "^4.0.0"
  },
  "publishConfig": { "access": "public" }
}
