{
  "name": "@agency/browser",
  "version": "0.1.0",
  "description": "Agency CLI autonomous browser automation and workflow runtime",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=22" },
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
